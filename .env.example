# Security Tools Pro — Environment Variables
# Copy this file to .env and fill in your values.
# Only SonarQube requires credentials; all other tools work with public APIs.

# ============================================================================
# SONARQUBE (SAST — 8 tools)
# ============================================================================
# Required only if you use sast_* tools. Leave empty to disable SonarQube.
SONARQUBE_URL=
SONARQUBE_TOKEN=

# ============================================================================
# CWE CATALOG (reproducibility)
# ============================================================================
# Pin a specific CWE catalog version by its SHA-256 hash.
# When set, the server validates the downloaded CSV against this hash.
# Empty = use the latest fetched version (no pinning).
# Default: "" (no pinning)
# CWE_CSV_SHA256=

# ============================================================================
# PATH (binary tool discovery)
# ============================================================================
# Ensure binary tools (nmap, trivy, gitleaks, etc.) are on PATH.
# On macOS with Homebrew, this is usually sufficient.
# PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
